{
  "Package with main": {
    "prefix": "pkg",
    "body": ["package main", "", "func main() {", "\t$0", "}"],
    "description": "Minimal package with an empty main"
  },
  "Function": {
    "prefix": "func",
    "body": ["func ${1:name}(${2}): ${3:String} {", "\t$0", "}"],
    "description": "Function with parameters and return type"
  },
  "Function (no result)": {
    "prefix": "funcv",
    "body": ["func ${1:name}(${2}) {", "\t$0", "}"],
    "description": "Function without a return type"
  },
  "Type alias": {
    "prefix": "type",
    "body": ["type ${1:Name} = ${2:String}"],
    "description": "Type alias"
  },
  "Import": {
    "prefix": "imp",
    "body": ["import \"${1:fmt}\""],
    "description": "Import path string"
  },
  "Ensure": {
    "prefix": "ensure",
    "body": ["ensure ${1:expr} is ${2:Nil()}", "\tor ${3:err}"],
    "description": "Ensure statement with or-branch"
  },
  "Use contract": {
    "prefix": "use",
    "body": ["use ${1:name}: ${2:Logger}"],
    "description": "Bind an ambient Usable contract in function body"
  },
  "With wiring": {
    "prefix": "with",
    "body": [
      "with {",
      "\t${1:Logger}: &${2:NopLogger} {},",
      "} {",
      "\t$0",
      "}"
    ],
    "description": "Wire Usables at a test or host boundary"
  },
  "Nested with (transitive)": {
    "prefix": "withnest",
    "body": [
      "with { ${1:Logger}: &${2:NopLogger} {} } {",
      "\twith { ${3:Clock}: &${4:FakeClock} { fixedMs: ${5:1000} } } {",
      "\t\t$0",
      "\t}",
      "}"
    ],
    "description": "Nested with: outer supplies contracts, inner overlays one key"
  }
}
