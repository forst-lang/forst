{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension (this folder = vscode-forst)",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/out/extension.js"],
      "preLaunchTask": "bun: compile"
    }
  ]
}
