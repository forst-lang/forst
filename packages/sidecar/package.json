{
  "name": "@forst/sidecar",
  "version": "0.1.8",
  "description": "Sidecar integration for TypeScript applications to use Forst for high-performance backend operations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "node ./scripts/rewrite-cli-workspace-dep-for-publish.mjs && bun install --cwd ../.. && bun run sync-jsr-version && bun run build",
    "sync-jsr-version": "node ./scripts/sync-jsr-version.mjs",
    "dev": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf dist",
    "build:clean": "bun run clean && bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "eslint src/**/*.ts",
    "example": "tsx examples/basic.ts"
  },
  "keywords": [
    "forst",
    "sidecar",
    "typescript",
    "performance",
    "backend"
  ],
  "author": "haveyaseen",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@forst/cli": "workspace:*",
    "chokidar": "^5.0.0",
    "glob": "^13.0.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "semver": "^7.7.2"
  },
  "devDependencies": {
    "@types/semver": "^7.7.1",
    "@types/bun": "^1.3.11",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "express": "^5.0.0"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forst-lang/forst.git",
    "directory": "packages/sidecar"
  }
}
