{
  "name": "@forst/sidecar",
  "version": "0.1.19",
  "description": "Sidecar integration for TypeScript applications to use Forst for high-performance backend operations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublish:sidecar": "bun run --cwd ../cli build && bun run sync-jsr-version && bun run build && node ./scripts/rewrite-cli-workspace-dep-for-publish.mjs && node ./scripts/assert-published-cli-dep.mjs",
    "prepublishOnly": "bun run prepublish:sidecar",
    "sync-jsr-version": "node ./scripts/sync-jsr-version.mjs",
    "dev": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf dist",
    "build:clean": "bun run clean && bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "eslint src/**/*.ts",
    "example": "tsx examples/basic.ts",
    "pack:dry": "npm pack --dry-run --ignore-scripts"
  },
  "keywords": [
    "forst",
    "sidecar",
    "typescript",
    "express",
    "dev-server",
    "performance",
    "backend"
  ],
  "author": "haveyaseen",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@forst/cli": "workspace:*",
    "chokidar": "^5.0.0",
    "glob": "^13.0.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "semver": "^7.7.2"
  },
  "devDependencies": {
    "@types/semver": "^7.7.1",
    "@types/bun": "^1.3.11",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "express": "^5.0.0"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forst-lang/forst.git",
    "directory": "packages/sidecar"
  },
  "homepage": "https://github.com/forst-lang/forst/tree/main/packages/sidecar#readme",
  "bugs": {
    "url": "https://github.com/forst-lang/forst/issues"
  }
}