{
  "version": "0.2.0",
  "configurations": [
    
    {
      "name": "Run Extension (vscode-forst)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/vscode-forst"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/vscode-forst/out/extension.js"
      ],
      "preLaunchTask": "compile: vscode-forst"
    }
  ]
}
