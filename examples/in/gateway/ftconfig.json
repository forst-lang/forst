{
  "compiler": {
    "target": "go",
    "optimization": "debug",
    "strict": false,
    "reportPhases": false,
    "reportMemoryUsage": false,
    "exportStructFields": true
  },
  "server": {
    "port": "8080",
    "readTimeout": 30,
    "writeTimeout": 30,
    "cors": false
  },
  "dev": {
    "logLevel": "error",
    "watch": false
  },
  "files": {
    "include": ["**/*.ft"],
    "exclude": ["**/node_modules/**", "**/.git/**"],
    "maxDepth": 12
  }
}
