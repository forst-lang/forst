package user

type User = {
  id: String,
  name: String,
  age: Int,
  email: String
}

type CreateUserRequest = {
  name: String,
  age: Int,
  email: String
}

type CreateUserResponse = {
  user: User,
  created_at: Int
}

is (u User) Valid {
  ensure u.name is Min(1)
  ensure u.age is GreaterThan(0)
  ensure u.age is LessThan(151)
  ensure u.name is Min(1)
  ensure u.email is Contains("@")
}

func CreateUser(input CreateUserRequest): Result(CreateUserResponse, Error) {
  created := {
    id: "123",
    name: input.name,
    age: input.age,
    email: input.email
  }

  ensure created is Valid

  return {
    user: created,
    created_at: 1234567890
  }
}

func GetUserById(id String) {
  // Simulate database lookup
  return {
    id: id,
    name: "John Doe",
    age: 30,
    email: "john@example.com"
  }
}

func UpdateUserAge(id String, newAge Int) {
  ensure newAge is GreaterThan(0)
  ensure newAge is LessThan(151)

  existing := GetUserById(id)
  updatedUser := {
    id: existing.id,
    name: existing.name,
    age: newAge,
    email: existing.email
  }

  ensure updatedUser is Valid

  return updatedUser
}
