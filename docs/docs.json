{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Forst",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.png",
  "styling": {
    "codeblocks": {
      "theme": "css-variables",
      "languages": {
        "custom": ["/languages/forst.json"]
      }
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "index",
              "why",
              "language/overview"
            ]
          },
          {
            "group": "Getting started",
            "pages": [
              "quickstart",
              "installation"
            ]
          },
          {
            "group": "Data validation",
            "pages": [
              "language/shapes-and-constraints",
              "language/ensure-and-narrowing",
              "language/type-guards"
            ]
          },
          {
            "group": "Behavior",
            "pages": [
              "language/errors-and-result",
              "language/providers"
            ]
          },
          {
            "group": "Interop",
            "pages": [
              "interop/go",
              {
                "group": "Node",
                "root": "interop/node",
                "pages": [
                  "interop/node/generate-types",
                  "interop/node/call-forst",
                  "interop/node/call-javascript"
                ]
              }
            ]
          },
          {
            "group": "Workflow",
            "pages": [
              "workflow/cli",
              "workflow/dev-server",
              "workflow/editor"
            ]
          }
        ]
      },
      {
        "tab": "Resources",
        "groups": [
          {
            "group": "Project",
            "pages": [
              "resources/llms",
              "resources/roadmap"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "For agents",
          "href": "/resources/llms",
          "icon": "robot"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/forst-lang/forst",
          "icon": "github"
        },
        {
          "anchor": "npm",
          "href": "https://www.npmjs.com/package/@forst/cli",
          "icon": "npm"
        },
        {
          "anchor": "Roadmap",
          "href": "https://github.com/forst-lang/forst/blob/main/ROADMAP.md",
          "icon": "map"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/icon.png",
    "dark": "/logo/icon.png"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/forst-lang/forst"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Quickstart",
      "href": "/quickstart"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/forst-lang/forst"
    }
  },
  "redirects": [
    {
      "source": "/interop/typescript",
      "destination": "/interop/node/generate-types",
      "permanent": true
    },
    {
      "source": "/interop/typescript-client",
      "destination": "/interop/node/call-forst",
      "permanent": true
    },
    {
      "source": "/interop/typescript-runtime",
      "destination": "/interop/node/call-javascript",
      "permanent": true
    },
    {
      "source": "/workflow/dev-server-and-sidecar",
      "destination": "/workflow/dev-server",
      "permanent": true
    }
  ]
}
